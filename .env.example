# ============================================================
# ENVIRONMENT VARIABLES — Cabana-Book
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git — it contains secrets.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API

# Your project's public REST URL (safe to expose client-side)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key — safe to expose; RLS policies protect the data
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=Cabana-Book
VITE_APP_URL=http://localhost:3000
